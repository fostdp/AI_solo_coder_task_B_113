# 数据库配置
DB_HOST=timescaledb
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=field_hospital
DB_SSLMODE=disable

# MQTT 配置
MQTT_BROKER=tcp://emqx:1883
MQTT_CLIENTID=field-hospital-backend
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
MQTT_CLEANSESSION=false
MQTT_KEEPALIVE=60

# 告警配置
ALERT_SOFA_THRESHOLD=2.0
ALERT_INFECTION_THRESHOLD=0.7
ALERT_SMS_GATEWAY=http://localhost:9090/sms
ALERT_DEDUPLICATION_WINDOW=5

# 模拟器配置
SIMULATOR_BROKER=tcp://emqx:1883
SIMULATOR_CLIENTID=sensor-simulator
SIMULATOR_BEDS=50
SIMULATOR_INTERVAL=1000
SIMULATOR_SEPSIS_MODE=normal
SIMULATOR_SEPSIS_DURATION=300

# Grafana 配置
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# 时区
TZ=Asia/Shanghai
